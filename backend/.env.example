# Gas Inpex — Пример файла переменных окружения
# Скопируйте в .env и заполните своими значениями

# --- Django ---
DJANGO_SECRET_KEY=django-insecure-замените-на-реальный-ключ
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# --- База данных (PostgreSQL) ---
DB_ENGINE=django.db.backends.postgresql
DB_NAME=gas_inpex
DB_USER=gas_inpex
DB_PASSWORD=gas_inpex
DB_HOST=localhost
DB_PORT=5432

# --- CORS ---
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# --- Статика и медиа ---
STATIC_URL=/static/
STATIC_ROOT=staticfiles
MEDIA_URL=/media/
MEDIA_ROOT=media