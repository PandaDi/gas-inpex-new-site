# ═══════════════════════════════════════════
# Gas Inpex — Production Environment Template
# ═══════════════════════════════════════════
# Copy to .env.prod (without .example) and fill in real values
# !!! .env.prod is in .gitignore — never commit secrets !!!

# Django
DJANGO_SETTINGS_MODULE=config.settings.prod
DJANGO_SECRET_KEY=generate-a-strong-secret-key-here
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=gas-inpex.kz,www.gas-inpex.kz,localhost

# PostgreSQL
DB_NAME=gasinpex
DB_USER=gasinpex
DB_PASSWORD=change-this-to-strong-password
DB_HOST=postgres
DB_PORT=5432

# CORS — разрешённые домены для фронтенда
CORS_ALLOWED_ORIGINS=https://gas-inpex.kz,https://www.gas-inpex.kz

# CSRF
CSRF_TRUSTED_ORIGINS=https://gas-inpex.kz,https://www.gas-inpex.kz

# Next.js
NEXT_PUBLIC_API_URL=https://gas-inpex.kz/api

# Static & Media URLs (with CDN or S3 if used)
# STATIC_URL=/static/
# MEDIA_URL=/media/